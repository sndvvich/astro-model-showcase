--- @jsxRuntime automatic @jsxImportSource astro ---
import './style.css';

interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<article class="capability-card">
  <span class="card-icon">{icon}</span>
  <h3>{title}</h3>
  <p>{description}</p>
</article>
